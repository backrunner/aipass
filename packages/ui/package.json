{
  "name": "@aipass/ui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": [
    "*.scss"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "svelte": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./i18n": {
      "types": "./src/i18n.ts",
      "svelte": "./src/i18n.ts",
      "default": "./src/i18n.ts"
    },
    "./styles/base.scss": "./src/styles/base.scss"
  },
  "scripts": {
    "lint": "svelte-check --tsconfig ./tsconfig.json",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@aipass/schemas": "workspace:*"
  },
  "peerDependencies": {
    "bits-ui": "^2.13.0",
    "lucide-svelte": "^0.555.0",
    "svelte": "^5.38.0"
  },
  "devDependencies": {
    "@aipass/tsconfig": "workspace:*",
    "bits-ui": "^2.13.0",
    "lucide-svelte": "^0.555.0",
    "sass": "^1.100.0",
    "svelte": "^5.38.0",
    "svelte-check": "^4.3.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.13"
  }
}
